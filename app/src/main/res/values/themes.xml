<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.TaxiEasyUa" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/zamov</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">@color/zamov</item>
        <item name="popupMenuStyle">@style/CustomPopupMenu</item>
        <item name="actionOverflowMenuStyle">@style/CustomPopupMenu</item>
        <item name="android:itemTextAppearance">@style/PopupMenuTextAppearance</item>
    </style>

    <style name="CustomPopupMenu" parent="Widget.AppCompat.PopupMenu.Overflow">
        <item name="android:popupBackground">@drawable/popup_menu_background</item>
        <item name="android:overlapAnchor">true</item>
        <item name="android:paddingTop">0dp</item>
        <item name="android:paddingBottom">0dp</item>
        <item name="android:paddingLeft">0dp</item>
        <item name="android:paddingRight">0dp</item>
        <item name="android:textColor">@color/popup_menu_text</item>
        <item name="android:textColorPrimary">@color/popup_menu_text</item>
    </style>

    <style name="PopupMenuTextAppearance" parent="TextAppearance.AppCompat.Widget.PopupMenu.Large">
        <item name="android:textColor">@color/popup_menu_text</item>
    </style>

    <style name="Theme.TaxiEasyUa.NoActionBar">
        <item name="android:windowBackground">@color/background_color_new</item>
        <item name="windowActionBar">true</item>
        <item name="windowNoTitle">true</item>
        <item name="android:textColor">@color/app_primary_text</item>
        <item name="popupMenuStyle">@style/CustomPopupMenu</item>
        <item name="actionOverflowMenuStyle">@style/CustomPopupMenu</item>
    </style>

    <style name="Theme.TaxiEasyUa.AppBarOverlay" parent="ThemeOverlay.AppCompat.Dark.ActionBar" />

    <style name="Theme.TaxiEasyUa.PopupOverlay" parent="ThemeOverlay.AppCompat.DayNight">
        <item name="android:colorBackground">@color/popup_menu_background</item>
        <item name="android:textColorPrimary">@color/popup_menu_text</item>
        <item name="android:textColor">@color/popup_menu_text</item>
        <item name="android:itemTextAppearance">@style/PopupMenuTextAppearance</item>
    </style>

    <style name="BugReportDialogTheme" parent="Theme.MaterialComponents.DayNight.Dialog.Alert">
        <item name="android:background">@color/dialog_background</item>
        <item name="colorSurface">@color/dialog_background</item>
        <item name="android:colorBackground">@color/dialog_background</item>
        <item name="android:textColorPrimary">@color/dialog_text_primary</item>
        <item name="android:textColor">@color/dialog_text_primary</item>
        <item name="colorOnSurface">@color/dialog_text_primary</item>
    </style>

    <style name="BugReportTextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/dialog_input_stroke</item>
        <item name="hintTextColor">@color/dialog_text_secondary</item>
        <item name="android:textColorHint">@color/dialog_text_secondary</item>
    </style>

    <style name="AlertDialogTheme" parent="BugReportDialogTheme">
        <item name="buttonBarPositiveButtonStyle">@style/Alert.Button.Positive</item>
        <item name="buttonBarNeutralButtonStyle">@style/Alert.Button.Neutral</item>
        <item name="buttonBarNegativeButtonStyle">@style/Alert.Button.Negative</item>
    </style>

    <style name="Alert.Button.Positive" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="backgroundTint">@color/zamov</item>
        <item name="rippleColor">@color/colorAccent</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="android:textSize">16sp</item>
        <item name="android:listPreferredItemPaddingLeft">2sp</item> <!-- Измените правый отступ по своему усмотрению -->
        <item name="android:fontFamily">@font/medium</item>
    </style>

    <style name="Alert.Button.Neutral" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="backgroundTint">@android:color/transparent</item>
        <item name="rippleColor">@color/colorAccent</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="android:textSize">16sp</item>
        <item name="android:layout_width">wrap_content</item>
        <item name="android:paddingRight">8sp</item> <!-- Измените правый отступ по своему усмотрению -->
        <item name="android:fontFamily">@font/medium</item>
    </style>

    <style name="Alert.Button.Negative" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="backgroundTint">@android:color/transparent</item>
        <item name="rippleColor">@color/colorAccent</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="android:textSize">16sp</item>
        <item name="android:layout_width">wrap_content</item>
        <item name="android:fontFamily">@font/medium</item>

    </style>

    <style name="LeftNavigation">
        <item name="android:background">@android:color/transparent</item>
        <item name="itemTextColor">@color/colorAccent</item>
    </style>




</resources>