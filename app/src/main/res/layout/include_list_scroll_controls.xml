<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:minHeight="@dimen/address_scroll_bar_height"
    android:orientation="horizontal"
    android:paddingTop="2dp"
    android:paddingBottom="2dp">

    <LinearLayout
        android:id="@+id/scrollButtonUp"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginEnd="4dp"
        android:layout_weight="1"
        android:background="@drawable/button_outline_scroll_up"
        android:clickable="true"
        android:contentDescription="@string/scroll_list_up"
        android:focusable="true"
        android:gravity="center"
        android:minHeight="@dimen/address_scroll_button_height"
        android:orientation="vertical"
        android:paddingStart="6dp"
        android:paddingTop="4dp"
        android:paddingEnd="6dp"
        android:paddingBottom="4dp">

        <ImageView
            android:layout_width="@dimen/address_scroll_icon_width"
            android:layout_height="@dimen/address_scroll_icon_height"
            android:importantForAccessibility="no"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_scroll_chevron_up" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvScrollPosition"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="4dp"
        android:layout_marginEnd="4dp"
        android:fontFamily="@font/regular"
        android:gravity="center"
        android:minWidth="40dp"
        android:text="1 / 1"
        android:textColor="@color/text_btn"
        android:textSize="12sp"
        android:visibility="visible"
        tools:text="1 / 6" />

    <LinearLayout
        android:id="@+id/scrollButtonDown"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="4dp"
        android:layout_weight="1"
        android:background="@drawable/button_outline_scroll_down"
        android:clickable="true"
        android:contentDescription="@string/scroll_list_down"
        android:focusable="true"
        android:gravity="center"
        android:minHeight="@dimen/address_scroll_button_height"
        android:orientation="vertical"
        android:paddingStart="6dp"
        android:paddingTop="4dp"
        android:paddingEnd="6dp"
        android:paddingBottom="4dp">

        <ImageView
            android:layout_width="@dimen/address_scroll_icon_width"
            android:layout_height="@dimen/address_scroll_icon_height"
            android:importantForAccessibility="no"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_scroll_chevron_down" />
    </LinearLayout>

</LinearLayout>
