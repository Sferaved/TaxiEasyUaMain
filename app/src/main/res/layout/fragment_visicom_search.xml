<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/new_background_color">

    <!-- Увеличенный текст "Откуда" -->
    <TextView
        android:id="@+id/textfrom"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24sp"
        android:layout_marginTop="16dp"
        android:fontFamily="@font/light"
        android:text="@string/from_text"
        android:textColor="@color/white"
        android:textSize="18sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/num1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8sp"
        android:layout_marginTop="8sp"
        android:fontFamily="@font/regular"
        android:text="1"
        android:textColor="@color/white"
        android:textSize="16sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textfrom" />

    <EditText
        android:id="@+id/textGeo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:minHeight="40dp"
        android:layout_margin="8sp"
        android:layout_marginStart="14sp"
        android:background="@drawable/input"
        android:ems="10"
        android:fontFamily="@font/light"
        android:hint="@string/Street_hint"
        android:textColor="@color/white"
        android:textColorHint="#ABD9D9D9"
        android:textSize="@dimen/textView_textSize"
        android:importantForAutofill="no"
        android:imeOptions="actionNext"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/num1"
        app:layout_constraintTop_toBottomOf="@+id/textfrom"
        app:layout_constraintWidth_percent="@dimen/button_width" />

    <TextView
        android:id="@+id/textGeoError"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:background="@drawable/error"
        android:gravity="center"
        android:textColor="@color/white"
        android:textSize="12sp"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.216"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textGeo" />

    <!-- Увеличенный текст "Куда" -->
    <TextView
        android:id="@+id/textwhere"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24sp"
        android:layout_marginTop="16dp"
        android:fontFamily="@font/light"
        android:text="@string/to_edit"
        android:textColor="@color/white"
        android:textSize="18sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textGeoError" />

    <TextView
        android:id="@+id/num2"
        android:layout_width="9dp"
        android:layout_height="18dp"
        android:layout_marginStart="8sp"
        android:layout_marginTop="8sp"
        android:fontFamily="@font/regular"
        android:text="2"
        android:textColor="@color/white"
        android:textSize="16sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textwhere" />

    <EditText
        android:id="@+id/text_to"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:minHeight="40dp"
        android:layout_margin="8sp"
        android:layout_marginStart="8sp"
        android:layout_marginTop="8sp"
        android:background="@drawable/input"
        android:ems="10"
        android:fontFamily="@font/light"
        android:hint="@string/Street_hint"
        android:textColor="@color/white"
        android:textColorHint="#ABD9D9D9"
        android:textSize="@dimen/textView_textSize"
        android:imeOptions="actionDone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/num2"
        app:layout_constraintTop_toBottomOf="@+id/textwhere"
        app:layout_constraintWidth_percent="@dimen/button_width" />

    <TextView
        android:id="@+id/text_toError"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:background="@drawable/error"
        android:gravity="center"
        android:textColor="@color/white"
        android:textSize="12sp"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.216"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/text_to" />

    <ListView
        android:id="@+id/listAddress"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="8dp"
        android:layout_marginTop="8dp"
        android:scrollbarThumbVertical="@color/colorYellow"
        app:layout_constraintBottom_toTopOf="@+id/bottomBar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/text_toError"
        app:layout_constraintVertical_bias="0"
        app:layout_constraintVertical_weight="1"
        app:layout_constraintWidth_percent="@dimen/button_width" />

    <!-- НИЖНЯЯ ПАНЕЛЬ - LinearLayout чтобы кнопки не накладывались -->
    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        android:layout_marginBottom="20dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:weightSum="100"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- Кнопка назад -->
        <ImageButton
            android:id="@+id/btn_no"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/btn_accents"
            android:scaleType="centerInside"
            android:src="@drawable/arrow_back_fill0_wght400_grad0_opsz24" />

        <!-- ProgressBar -->
        <ProgressBar
            android:id="@+id/progress_bar_visicom"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginStart="4dp"
            android:visibility="gone" />

        <!-- Кнопка смены режима -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/change"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/buttons"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:text="@string/change"
            android:textColor="#D9D9D9"
            android:textSize="13sp" />

        <!-- Кнопка "На карте" - растягивается на оставшееся место -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_on_map"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:layout_weight="100"
            android:background="@drawable/buttons"
            android:fontFamily="@font/regular"
            android:text="@string/on_map"
            android:textAlignment="center"
            android:textColor="@color/white"
            android:textSize="14sp" />

    </LinearLayout>

    <!-- scroll_buttons_container (не трогаем) -->
    <LinearLayout
        android:id="@+id/scroll_buttons_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@+id/bottomBar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ImageButton
            android:id="@+id/scrollButtonUp"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_margin="8dp"
            android:background="@drawable/round_button_background"
            android:src="@drawable/up_arrow" />

        <ImageButton
            android:id="@+id/scrollButtonDown"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_margin="8dp"
            android:background="@drawable/round_button_background"
            android:src="@drawable/down_arrow" />
    </LinearLayout>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnCallAdmin"
        android:layout_width="0dp"
        android:layout_height="@dimen/button_height"
        android:layout_margin="16dp"
        android:background="@drawable/buttons"
        android:fontFamily="@font/regular"
        android:text="@string/call_admin"
        android:textAlignment="center"
        android:textColor="#D9D9D9"
        android:textSize="@dimen/textView_textSize"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@+id/bottomBar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintWidth_percent="@dimen/button_width" />

    <ImageButton
        android:id="@+id/btn_ok"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_margin="16dp"
        android:layout_marginBottom="24dp"
        android:background="@drawable/btn_accents"
        android:scaleType="centerInside"
        android:src="@drawable/baseline_check_black_24dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>