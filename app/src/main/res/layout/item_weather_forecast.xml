<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="4dp"
    android:layout_marginVertical="5dp"
    app:cardBackgroundColor="@color/uklon_surface"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/uklon_outline"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="14dp"
        android:paddingVertical="12dp">

        <TextView
            android:id="@+id/tv_day"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:fontFamily="@font/medium"
            android:textColor="@color/uklon_on_surface"
            android:textSize="15sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@id/iv_order_action"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="Понеділок" />

        <TextView
            android:id="@+id/tv_date"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:fontFamily="@font/regular"
            android:textColor="@color/uklon_on_surface_secondary"
            android:textSize="12sp"
            app:layout_constraintEnd_toStartOf="@id/iv_order_action"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_day"
            tools:text="15 січ" />

        <ImageView
            android:id="@+id/iv_order_action"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_author_stat_chip"
            android:clickable="true"
            android:contentDescription="@string/shortcut_order_long"
            android:focusable="true"
            android:padding="9dp"
            android:src="@drawable/ic_order_arrow"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/uklon_yellow" />

        <ImageView
            android:id="@+id/iv_weather_icon"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginTop="12dp"
            android:contentDescription="@string/weather_title"
            android:src="@drawable/ic_weather_default"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_date" />

        <TextView
            android:id="@+id/tv_description"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="8dp"
            android:ellipsize="end"
            android:fontFamily="@font/regular"
            android:maxLines="2"
            android:textColor="@color/uklon_on_surface_secondary"
            android:textSize="13sp"
            app:layout_constraintBottom_toBottomOf="@id/iv_weather_icon"
            app:layout_constraintEnd_toStartOf="@id/temp_block"
            app:layout_constraintStart_toEndOf="@id/iv_weather_icon"
            app:layout_constraintTop_toTopOf="@id/iv_weather_icon"
            tools:text="Хмарно з проясненнями" />

        <LinearLayout
            android:id="@+id/temp_block"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="@id/iv_weather_icon"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/iv_weather_icon">

            <TextView
                android:id="@+id/tv_temp_max"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/medium"
                android:textColor="@color/uklon_on_surface"
                android:textSize="18sp"
                android:textStyle="bold"
                tools:text="+8°" />

            <TextView
                android:id="@+id/tv_temp_min"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/regular"
                android:textColor="@color/uklon_on_surface_secondary"
                android:textSize="14sp"
                tools:text="−2°" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/iv_weather_icon">

            <TextView
                android:id="@+id/tv_pop"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_weather_pop_chip"
                android:fontFamily="@font/medium"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:textColor="@color/uklon_on_surface"
                android:textSize="11sp"
                android:visibility="gone"
                tools:text="Дощ 60%"
                tools:visibility="visible" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:contentDescription="@string/humidity"
                android:src="@drawable/ic_humidity_small"
                app:tint="@color/uklon_on_surface_secondary" />

            <TextView
                android:id="@+id/tv_humidity"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:fontFamily="@font/medium"
                android:textColor="@color/uklon_on_surface_secondary"
                android:textSize="12sp"
                tools:text="65%" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
