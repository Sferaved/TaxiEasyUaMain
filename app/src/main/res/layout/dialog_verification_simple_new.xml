<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:elevation="8dp">

    <!-- Верхняя панель с крестиком -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp">

        <!-- Иконка по центру (можно убрать, если не нужна) -->
        <ImageView
            android:id="@+id/ivIcon"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_centerHorizontal="true"
            android:src="@drawable/ic_verification"
            android:visibility="gone" /> <!-- Скрываем иконку, если не нужна -->

        <!-- Красная круглая кнопка с крестиком справа -->
        <ImageButton
            android:id="@+id/btnClose"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_alignParentEnd="true"
            android:layout_alignParentRight="true"
            android:background="@drawable/circle_close_button"
            android:src="@drawable/ic_close_white"
            android:contentDescription="@string/close"
            android:scaleType="centerInside"
            android:padding="8dp" />

    </RelativeLayout>

    <!-- Заголовок -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:text="@string/verification_required_title"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#1A1A2E"
        android:layout_marginBottom="8dp" />

    <!-- Сообщение -->
    <TextView
        android:id="@+id/tvMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/verification_required_message"
        android:textSize="14sp"
        android:textColor="#555555"
        android:gravity="center"
        android:layout_marginBottom="24dp"
        android:lineSpacingExtra="4dp" />

    <!-- Кнопка Старт -->
    <Button
        android:id="@+id/btnPositive"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="@string/start"
        android:textSize="16sp"
        android:textColor="@android:color/white"
        android:textStyle="bold"
        android:background="@drawable/button_gradient_positive"
        android:stateListAnimator="@null"
        android:elevation="0dp" />

</LinearLayout>