<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="24dp"
    android:layout_marginEnd="24dp"
    android:background="@drawable/bg_dialog_rounded"
    android:orientation="vertical"
    android:paddingStart="24dp"
    android:paddingTop="28dp"
    android:paddingEnd="24dp"
    android:paddingBottom="20dp">

    <FrameLayout
        android:id="@+id/alertIconContainer"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_gravity="center_horizontal"
        android:background="@drawable/bg_dialog_icon_circle_soft">

        <ImageView
            android:id="@+id/alertIcon"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_gravity="center"
            android:importantForAccessibility="no"
            app:tint="@color/zamov"
            tools:src="@drawable/ic_info" />
    </FrameLayout>

    <TextView
        android:id="@+id/alertTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="center"
        android:textColor="@color/uklon_on_surface"
        android:textSize="18sp"
        android:textStyle="bold"
        tools:text="Заголовок" />

    <TextView
        android:id="@+id/alertMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:textColor="@color/uklon_on_surface_secondary"
        android:textSize="15sp"
        tools:text="Текст сообщения диалога" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/alertBtnNegative"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:background="@drawable/bg_dialog_btn_cancel"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:textColor="@color/uklon_on_surface"
            android:textSize="15sp"
            tools:text="@string/cancel" />

        <TextView
            android:id="@+id/alertBtnPositive"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:background="@drawable/bg_dialog_btn_primary"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:textStyle="bold"
            tools:text="@string/ok" />
    </LinearLayout>
</LinearLayout>
